{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Apple Music History Converter",
  "version": "3.0.1",
  "identifier": "com.nerveband.apple-music-history-converter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:release",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Apple Music History Converter",
        "width": 1150,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: https:; connect-src 'self' https://itunes.apple.com https://musicbrainz.org https://am-proxy.wavedepth.workers.dev; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../python-sidecar/dist/*": "python-sidecar/",
      "../python-sidecar/sidecar.py": "python-sidecar/sidecar.py",
      "../python-sidecar/requirements.txt": "python-sidecar/requirements.txt",
      "../../src/apple_music_history_converter/**/*": "src/apple_music_history_converter/"
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-",
      "entitlements": null
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    },
    "fileAssociations": [
      {
        "ext": ["csv"],
        "mimeType": "text/csv",
        "name": "CSV File",
        "role": "Viewer"
      }
    ]
  }
}
